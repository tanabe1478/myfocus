{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "myfocus",
  "version": "0.1.0",
  "identifier": "jp.tanabe.myfocus",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "myfocus",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600
      },
      {
        "label": "settings",
        "title": "myfocus 設定",
        "url": "settings.html",
        "width": 520,
        "height": 620,
        "minWidth": 440,
        "minHeight": 520,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
